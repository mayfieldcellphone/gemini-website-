{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node dist/server.cjs",
    "build": "npx tsx scripts/generate-sitemap.ts && vite build && npx tsx scripts/prerender.ts && esbuild server.ts --bundle --platform=node --format=cjs --outfile=dist/server.cjs --external:vite --external:express --external:path --external:dotenv",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "export-github": "npx tsx scripts/github-export.ts",
    "deploy:hostinger": "npx tsx scripts/deploy-hostinger.ts"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@octokit/rest": "^22.0.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/nodemailer": "^8.0.0",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@vitejs/plugin-react": "^5.0.4",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "express": "^4.22.1",
    "firebase": "^12.12.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "nodemailer": "^8.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-firebase-hooks": "^5.1.1",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.14.2",
    "ssh2-sftp-client": "^12.1.1",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@firebase/eslint-plugin-security-rules": "^0.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
