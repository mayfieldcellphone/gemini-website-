rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == 'mayfieldcellphonerepairs@gmail.com' && request.auth.token.email_verified == true)
      );
    }

    // Schema Validations
    function isValidBooking(data) {
      return data.keys().hasAll(['customerName', 'phone', 'category', 'brand', 'model', 'service', 'date', 'time', 'status', 'createdAt', 'updatedAt'])
        && data.customerName is string && data.customerName.size() <= 100
        && data.phone is string && data.phone.size() <= 20
        && data.status in ['pending', 'confirmed', 'completed', 'cancelled']
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidQuote(data) {
      return data.keys().hasAll(['name', 'phone', 'details', 'status', 'createdAt', 'updatedAt'])
        && data.name is string && data.name.size() <= 100
        && data.phone is string && data.phone.size() <= 20
        && data.details is string && data.details.size() <= 2000
        && data.status in ['pending', 'contacted', 'completed', 'cancelled'];
    }

    function isValidLead(data) {
      return data.keys().hasAll(['customerName', 'message', 'type', 'status', 'createdAt'])
        && data.customerName is string && data.customerName.size() <= 100
        && data.message is string && data.message.size() <= 2000
        && data.type in ['contact', 'quote', 'booking']
        && data.status in ['new', 'viewed', 'archived']
        && data.createdAt is string; // The app sends ISO string
    }

    // Match Blocks
    match /bookings/{bookingId} {
      allow create: if isValidId(bookingId) && isValidBooking(incoming()) 
        && incoming().status == 'pending' 
        && incoming().createdAt == request.time;
      allow read, update, delete: if isAdmin();
    }

    match /quotes/{quoteId} {
      allow create: if isValidId(quoteId) && isValidQuote(incoming())
        && incoming().status == 'pending'
        && incoming().createdAt == request.time;
      allow read, update, delete: if isAdmin();
    }

    match /users/{userId}/leads/{leadId} {
      // Allow public creation for the target inbox user
      allow create: if userId == 'BSOiqXCyZ9M25962BnJI7K9Mh8G2' 
        && isValidId(leadId) 
        && isValidLead(incoming())
        && incoming().status == 'new';
      // Only admin or the owner (if they are signed in as that UID) can read
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
    }

    match /chats/{chatId} {
      allow create: if isValidId(chatId);
      allow read, update: if true; // Public chat access
      
      match /messages/{messageId} {
        allow create: if isValidId(messageId) && incoming().isAdmin == false;
        allow read: if true;
      }
    }
  }
}
