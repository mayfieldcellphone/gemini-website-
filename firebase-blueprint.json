{
  "entities": {
    "quote": {
      "title": "Quote Request",
      "description": "Customer inquiry for a repair quote",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Customer name" },
        "phone": { "type": "string", "description": "Customer phone number" },
        "details": { "type": "string", "description": "Repair details" },
        "status": { "type": "string", "enum": ["pending", "contacted", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone", "details", "status", "createdAt", "updatedAt"]
    },
    "corporate_inquiry": {
      "title": "Corporate Inquiry",
      "description": "B2B or school repair inquiry",
      "type": "object",
      "properties": {
        "organization": { "type": "string", "description": "Organization name" },
        "contactName": { "type": "string", "description": "Primary contact name" },
        "email": { "type": "string", "description": "Corporate email" },
        "phone": { "type": "string", "description": "Contact phone" },
        "message": { "type": "string", "description": "Inquiry details" },
        "status": { "type": "string", "enum": ["new", "scheduled", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["organization", "contactName", "email", "phone", "status", "createdAt"]
    },
    "chat_message": {
      "title": "Chat Message",
      "description": "A single message in a chat conversation",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "senderId", "senderName", "isAdmin", "timestamp"]
    },
    "chat_session": {
      "title": "Chat Session",
      "description": "A live chat conversation between a customer and staff",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "archived"] },
        "lastMessage": { "type": "string" },
        "lastUpdatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["status", "lastUpdatedAt", "createdAt"]
    },
    "booking": {
      "title": "Repair Booking",
      "description": "A scheduled repair appointment",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "serviceType": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "details": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "phone", "serviceType", "date", "time", "status", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "bookings": {
      "schema": "booking",
      "description": "Collection of repair appointments"
    },
    "quotes": {
      "schema": "quote",
      "description": "Collection of public quote requests"
    },
    "corporate_leads": {
      "schema": "corporate_inquiry",
      "description": "Collection of corporate leads"
    },
    "chats": {
      "schema": "chat_session",
      "description": "Active and archived chat sessions"
    },
    "chats/{chatId}/messages": {
      "schema": "chat_message",
      "description": "Messages within a specific chat session"
    }
  }
}
